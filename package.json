{
  "name": "ai-search",
  "version": "0.0.0",
  "private": true,
  "description": "Desktop AI search for local files — Spotlight + ChatGPT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w apps/desktop run dev",
    "build": "npm -w apps/desktop run build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
